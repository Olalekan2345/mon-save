# MonSave API — copy to .env and fill in. Never commit real values.

MONSAVE_NETWORK=monad-testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# MONAD_RPC_FALLBACK_URL=
CONFIRMATIONS=2

DATABASE_URL=postgresql://monsave:monsave@localhost:5432/monsave
REDIS_URL=redis://localhost:6379

# 32+ chars, randomly generated. e.g. `openssl rand -hex 32`
SESSION_SECRET=

API_PORT=4000
CORS_ORIGIN=http://localhost:3000
SIWE_DOMAIN=localhost:3000
SIWE_URI=http://localhost:3000
RATE_LIMIT_MAX=60

# CIRCLE_FACTORY_ADDRESS=
# SENTRY_DSN=
