# MonSave settlement worker — copy to .env. Never commit real values.

MONSAVE_NETWORK=monad-testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CONFIRMATIONS=2

DATABASE_URL=postgresql://monsave:monsave@localhost:5432/monsave
REDIS_URL=redis://localhost:6379

# Factory address from the deployment manifest — the worker refuses to run without it.
# CIRCLE_FACTORY_ADDRESS=

# Automation signer: path to a runtime-mounted key file from your secret
# manager. WITHOUT it the worker runs observe-only. The signer must hold no
# protocol roles and only enough MON for gas.
# AUTOMATION_KEYSTORE_PATH=/run/secrets/monsave-automation-key

SETTLEMENT_POLL_INTERVAL_MS=30000
SETTLEMENT_MAX_RETRIES=5
