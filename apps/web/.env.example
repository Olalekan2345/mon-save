# MonSave web — copy to .env.local and fill in. Never commit real values.

# Which single network this deployment serves: monad-mainnet | monad-testnet | local
NEXT_PUBLIC_MONSAVE_NETWORK=monad-testnet

# RPC for the active network (defaults come from packages/config chains)
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# CircleFactory address from the deployment manifest for the active network.
# Leave unset until deployed — the app shows honest "not deployed" states.
# NEXT_PUBLIC_CIRCLE_FACTORY_ADDRESS=

# Reown AppKit project id — create at https://dashboard.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=

# MonSave API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public URL of this app (used in wallet metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
